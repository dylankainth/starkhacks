# ── Pony Stark Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The C++ app reads env vars directly; source .env before running:
#   export $(grep -v '^#' .env | xargs) && ./build/astrosplat

# ── AI Inference (at least one required for planet generation) ───────────────

# Google Gemini (PREFERRED — used for "Best Use of Gemini" track)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (fallback — fast inference)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=

# AWS Bedrock (optional — requires AWS CLI configured with credentials)
# Uses ~/.aws/credentials or these env vars:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ── Gesture Input ────────────────────────────────────────────────────────────
# iPhone HoloGesture app streams gestures via UDP.
# Make sure your iPhone and laptop are on the same WiFi network.
GESTURE_PORT=9001

# ── Hologram Quad-View ───────────────────────────────────────────────────────
# HOLO_SCALE: divider for quad-view face size (higher = smaller faces)
#   Range 1-20, default 5. Use 3-4 for large displays, 6-8 for small pyramids.
HOLO_SCALE=5
# HOLO_GAP: gap between faces as fraction of face size (0.0 - 1.0)
#   Default 0.25 (25% of face size)
HOLO_GAP=0.25

# ── Solana (for contribution web app) ────────────────────────────────────────
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_PROGRAM_ID=  (deployed Anchor program address)
